<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MinimalDemo.MainPage"
             Title="Ferrum Minimal Demo">

    <VerticalStackLayout Spacing="16" Padding="24" VerticalOptions="Center">

        <Label Text="Ferrum Framework"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Label Text="Native P/Invoke end-to-end demo"
               FontSize="14"
               TextColor="Gray"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

        <Label Text="Call ferrum_add(21, 21) via [LibraryImport]:"
               FontSize="16" />

        <Button x:Name="CallNativeButton"
                Text="Call Native add()"
                Clicked="OnCallNativeClicked"
                HorizontalOptions="Center" />

        <Label x:Name="ResultLabel"
               Text="Result will appear here"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="DarkBlue" />

        <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

        <Label Text="Zero-copy buffer demo (NativeBuffer&lt;float&gt;):"
               FontSize="16" />

        <Button x:Name="BufferButton"
                Text="Pin a float buffer"
                Clicked="OnBufferDemoClicked"
                HorizontalOptions="Center" />

        <Label x:Name="BufferLabel"
               Text="Buffer info will appear here"
               FontSize="14"
               HorizontalOptions="Center"
               TextColor="DarkGreen" />

    </VerticalStackLayout>

</ContentPage>
