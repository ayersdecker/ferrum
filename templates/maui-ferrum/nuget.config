<!--
  nuget.config — scaffolded by the maui-ferrum dotnet-new template.

  During development (before Ferrum.Framework is published to NuGet.org) you
  can serve the package from a local directory:

      # from your Ferrum repo root:
      dotnet pack src/Framework/Ferrum.Framework.csproj -o <path-to-local-feed>

  Then update the "local-packages" source below to point at that directory.
  Once the package is published to NuGet.org you can remove this file or leave
  it — the packageSourceMapping ensures only Ferrum.* resolves locally.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Uncomment and set the path to your local Ferrum package feed:
    <add key="local-packages" value="C:\path\to\local\feed" />
    -->
  </packageSources>
</configuration>
